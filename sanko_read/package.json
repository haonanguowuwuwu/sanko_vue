{
  "name": "sanko_read",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "dev:api": "vite --mode api",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs && node scripts/generate-sample-books.mjs",
    "copy-pdfjs-assets": "node scripts/copy-pdfjs-assets.mjs",
    "generate-samples": "node scripts/generate-sample-books.mjs",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "chardet": "^2.2.0",
    "element-plus": "^2.14.2",
    "fflate": "^0.8.3",
    "js-untar": "^2.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "mhtml2html": "^3.0.0",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^3.0.4",
    "rangy": "^1.3.0",
    "underscore": "^1.13.8",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@types/underscore": "^1.13.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
